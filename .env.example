# Copie este arquivo para .env e preencha com seus valores reais.
# O .env esta no .gitignore - nunca sera commitado.

# Chave da API do Gemini (gere em https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# E-mail (Gmail SMTP). A senha e a App Password de 16 caracteres
# gerada em https://myaccount.google.com/apppasswords (precisa 2FA).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=
